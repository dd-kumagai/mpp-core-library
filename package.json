{
  "name": "@mpp/core",
  "version": "0.1.0",
  "type": "module",
  "description": "MPP Core Design System - React component library",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
